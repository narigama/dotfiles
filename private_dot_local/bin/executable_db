def fish_completions(prog):
    top_cmds = " ".join(cli.commands)
    lines = []
    for name, cmd in cli.commands.items():
        desc = (cmd.help or "").split("\n")[0].replace("'", "\\'")
        lines.append(
            "complete -c {prog} -f -n 'not __fish_seen_subcommand_from {top}' -a {name} -d '{desc}'".format(
                prog=prog, top=top_cmds, name=name, desc=desc,
            )
        )
        if hasattr(cmd, "commands"):
            sub_cmds = " ".join(cmd.commands)
            for sub_name, sub_cmd in cmd.commands.items():
                sub_desc = (sub_cmd.help or "").split("\n")[0].replace("'", "\\'")
                lines.append(
                    "complete -c {prog} -f -n '__fish_seen_subcommand_from {name}; and not __fish_seen_subcommand_from {subs}' -a {sub_name} -d '{sub_desc}'".format(
                        prog=prog, name=name, subs=sub_cmds, sub_name=sub_name, sub_desc=sub_desc,
                    )
                )
    return "\n".join(lines)


@cli.command("completions")
@click.argument("shell", type=click.Choice(["bash", "zsh", "fish"]))
def completions(shell):
    """Print shell completion script. Example: db completions fish > ~/.config/fish/completions/db.fish"""
    if shell == "fish":
        click.echo(fish_completions("db"))
    else:
        from click.shell_completion import BashComplete, ZshComplete
        comp = {"bash": BashComplete, "zsh": ZshComplete}[shell](cli, {}, "db", "_DB_COMPLETE")
        click.echo(comp.source())


if __name__ == "__main__":
    cli()
